---
const items = [
  {
    title: 'NASA Space Apps Challenge Nigeria',
    detail: 'Winner — Project: My Earth Observer',
    year: '2014',
  },
  {
    title: 'The Future Awards Africa',
    detail: 'Technology Young Person of the Year — Finalist',
    year: '2015',
  },
  {
    title: 'LEAP Africa Social Innovators Program',
    detail: 'SIP Fellow — HealthBook Project (malaria/typhoid diagnosis platform)',
    year: '2014',
  },
  {
    title: 'Enactus Nigeria',
    detail: 'Technical Director & National Champion — Represented Nigeria at World Cup, Washington DC',
    year: '2012',
  },
];
---

<section id="achievements">
  <div class="container">
    <p class="section-label">Recognition</p>

    <div class="achievements-list">
      {items.map((item) => (
        <div class="achievement">
          <span class="achievement-year">{item.year}</span>
          <div class="achievement-body">
            <span class="achievement-title">{item.title}</span>
            <span class="achievement-detail">{item.detail}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .achievements-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .achievement {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: 1rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--border);
    align-items: start;
  }

  .achievement:first-child { padding-top: 0; }
  .achievement:last-child { border-bottom: none; }

  .achievement-year {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted);
    padding-top: 0.15rem;
  }

  .achievement-body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .achievement-title {
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--text);
  }

  .achievement-detail {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.5;
  }

  @media print {
    .achievement-title { font-size: 9.5pt; }
    .achievement-detail, .achievement-year { font-size: 8.5pt; }
  }
</style>
