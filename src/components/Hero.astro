<style>
  .hero-section {
    padding: 5rem 0 3.5rem;
    border-top: none;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 1;
    margin-bottom: 0.75rem;
  }

  h1 {
    color: var(--text);
    margin-bottom: 1.25rem;
  }

  .hero-summary {
    max-width: 560px;
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--text);
    opacity: 0.8;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-top: 1.25rem;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
  }

  .meta-item svg { flex-shrink: 0; }

  /* Links row */
  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
  }

  .link-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.9rem;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--muted);
    border: 1px solid var(--border);
    background: var(--surface);
    transition: color 0.15s, border-color 0.15s;
    cursor: pointer;
    font-family: var(--font-sans);
  }

  .link-pill:hover {
    color: var(--text);
    border-color: var(--accent-dim);
  }

  /* Print-only line */
  .print-only { display: none; }

  @media print {
    .hero-section { padding: 0 0 0.5rem; }
    .hero-inner { gap: 0.5rem; }
    .hero-text h1 { margin-bottom: 0.35rem; }
    .hero-meta { margin-top: 0.4rem; gap: 0.75rem; }
    .print-only {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      font-size: 8.5pt;
      color: var(--muted);
      margin-top: 0.25rem;
    }
    .print-only a { color: var(--accent); }
    h1 { font-size: 20pt; margin-bottom: 0.35rem; }
    .hero-eyebrow { font-size: 7.5pt; margin-bottom: 0.3rem; }
    .hero-summary { font-size: 9.5pt; line-height: 1.5; }
    .meta-item { font-size: 7.5pt; }
  }

  @media (max-width: 600px) {
    .hero-section { padding: 3rem 0 2rem; }
  }
</style>
